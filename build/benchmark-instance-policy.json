{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EcrPullAuth",
      "Effect": "Allow",
      "Action": "ecr:GetAuthorizationToken",
      "Resource": "*"
    },
    {
      "Sid": "EcrPull",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage"
      ],
      "Resource": "arn:aws:ecr:*:*:repository/gromacs-bench"
    },
    {
      "Sid": "S3StageAndResults",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::aws-gromacs-bench-*",
        "arn:aws:s3:::aws-gromacs-bench-*/*"
      ]
    }
  ]
}
